# --- SMTP Configuration ---
# For Gmail, you MUST use an App Password (not your normal password).
# 1. Enable 2FA on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an app password and paste it below.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-club-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-club-email@gmail.com
SMTP_USE_TLS=true

# Frontend origin(s) allowed to call this API (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
